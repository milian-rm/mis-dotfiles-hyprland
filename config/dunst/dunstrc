[global]
    monitor = 0
    follow = none
    width = 320
    height = (0, 200)
    origin = top-right
    offset = (15, 50)
    scale = 0
    notification_limit = 5

    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    progress_bar_corner_radius = 4

    icon_corner_radius = 6
    icon_corners = all

    indicate_hidden = yes
    transparency = 10
    separator_height = 1
    padding = 12
    horizontal_padding = 14
    text_icon_padding = 10
    frame_width = 2
    frame_color = "#ffffff"
    gap_size = 6
    separator_color = "#1e1e2e"
    sort = urgency_descending

    font = JetBrainsMono Nerd Font 10
    line_height = 2
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = end
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = no

    enable_recursive_icon_lookup = true
    icon_theme = Adwaita
    icon_position = left
    min_icon_size = 32
    max_icon_size = 48

    sticky_history = yes
    history_length = 20

    corner_radius = 10
    corners = all
    force_xwayland = false

    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[experimental]
    per_monitor_dpi = false
    pause_on_mouse_over = true

[urgency_low]
    background = "#0d0d0d"
    foreground = "#aaaaaa"
    frame_color = "#333333"
    timeout = 5

[urgency_normal]
    background = "#0d0d0d"
    foreground = "#ffffff"
    frame_color = "#ffffff"
    timeout = 8

[urgency_critical]
    background = "#0d0d0d"
    foreground = "#ffffff"
    frame_color = "#ff5555"
    timeout = 0
