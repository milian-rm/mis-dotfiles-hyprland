{

    "output": "eDP-1",
    "layer": "top",
    "width": 1366,
    "margin-top": 10,
    "margn-bottom": 0,

    //Modules layout

	"modules-left": ["custom/launcher","cpu","memory","disk", "custom/media"],
	"modules-center": ["hyprland/workspaces"],
	"modules-right": ["network","pulseaudio","backlight","clock","custom/power"],
	

    // Sourced modules

	"pulseaudio": {
		"tooltip": false,
		"scroll-step": 5,
		"format": "{icon} {volume}%",
		"format-muted": "{icon} {volume}%",
		"on-click":"pactl set-sink-mute @DEFAULT_SINK@ toggle",
		"format-icons": {
			"default": [
                "<span color='#ffffff'>пЂ¦ </span>", 
                "<span color='#ffffff'>пЂ§ </span>", 
                "<span color='#ffffff'>пЂЁ </span>"
            ]
		}
	},
"hyprland/workspaces": {
    "disable-scroll": true,
    "on-click": "activate",
    "all-outputs": false,
    "active-only": false,
    "on-scroll-down": "hyprctl dispatch workspace r+1",
    "on-scroll-up": "hyprctl dispatch workspace r-1",
    "persistent-workspaces": {
        "1": [], "2": [], "3": [],
        "4": [], "5": [], "6": []
    },
    "format": "{icon}",
    "format-icons": {
        "active": "<span font='12'>у°‹„</span>",
        "empty": "<span font='8'>у°‹†</span>",
        "persistent": "у°‹…",
        "default": "<span font='8'>у°‹†</span>"
    },
},
	"network": {
		"tooltip": false,
		"format-wifi": "<span color='#ffffff'>п‡« </span> {bandwidthDownBits}",
    "format-ethernet": "<span color='#ffffff'>у°€Ђ </span> {ifname}",
    "format-disconnected": "<span color='#ffffff'>у°–Є </span> Sin conexiГіn",
    "interval": 30
	},
	"backlight": {
		"tooltip": false,
		"format": "пѓ« {}%",
		"interval":1,
		"on-scroll-up": "brightnessctl set +5%",
	       "on-scroll-down": "brightnessctl set 5%-"
	},
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 10
        },
        "format": "{icon}  <span color='#ffffff'>{capacity}%</span>",
        "format-charging": "<span color='#ffffff'>п‡¦</span> <span color='#ffffff'>{capacity}%</span>",
        "format-plugged": "п‡¦ <span color='#ffffff'>{capacity}</span>%",
        "format-alt": "<span color='#ffffff'>{time}</span> {icon}",
        "format-icons": [
            "<span color='#ffffff'>п‰„</span>", 
            "<span color='#ffffff'>п‰ѓ</span>", 
            "<span color='#ffffff'>п‰‚</span>", 
            "<span color='#ffffff'>п‰Ѓ</span>", 
            "<span color='#ffffff'>п‰Ђ</span>"
        ]
    },

	"clock": {
        "tooltip": true,
        "interval": 60,
        "format": "{:%H:%M %p}",
        "tooltip-format": "{:%Y-%m-%d}",
    },

    "cpu": {
        "interval": 15,
        "format": "<span color='#ffffff'>п‹› </span> {}%",
        "max-length": 10
    },

    "disk": {
        "format": "<span color='#ffffff'>п€Ђ </span> {used}",
        "interval": 1,
    },

    "memory": {
        "interval": 30,
        "format": "<span color='#ffffff'>ої… </span> {used}GiB",
        "max-length": 10
    },


"custom/media": {
    "interval": 2,
    "format": "п†ј - {}",
    "return-type": "",
    "max-length": 30,
    "escape": true,
    "exec": "playerctl metadata --format '{{artist}} - {{title}}'",
    "on-click": "playerctl play-pause",
    "on-scroll-down": "playerctl next",
    "on-scroll-up": "playerctl previous"
},
    "custom/launcher":{
        "format": "пЊѓ ",
        "on-click": "rofi -show drun",
        "on-click-right": "killall rofi"
    },
    "custom/power":{
        "format": "<span color='#ffffff'>вЏ»</span>",
        "on-click": "wlogout -b 5 -m 0",
    },
    "custom/updates":{
        "format": "{} Update(s)",
        "exec": "checkupdates | wc -l",
        "exec-if": "[[ $(checkupdates | wc -l) != 0 ]]",
        "interval": 15,
        "on-click": "alacritty -e paru -Syu && notify-send 'The system has been updated' "
    },
    
}
